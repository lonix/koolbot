{
  "name": "koolbot",
  "version": "1.2.2",
  "type": "module",
  "description": "A modular Discord bot with voice channel management, activity tracking, quotes, stats, and fun easter eggs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc --listFiles --listEmittedFiles",
    "start": "node dist/index.js",
    "dev": "node --import ./src/loader.js src/index.ts",
    "watch": "tsc --watch",
    "unregister-guild-commands": "node dist/unregister-guild-commands.js",
    "cleanup-global-commands": "node dist/scripts/cleanup-global-commands.js",
    "migrate-config": "node dist/scripts/migrate-config.js",
    "validate-config": "node dist/scripts/validate-config.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --coverage --maxWorkers=2",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "npm run build && npm run lint && npm run format:check",
    "check:all": "npm run build && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "cron": "^4.4.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-yaml": "^4.2.0",
    "mongoose": "^9.6.3",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@jest/globals": "^30.4.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "undici": "^7.27.2"
  },
  "overrides": {
    "undici": "^7.27.2",
    "diff": "^8.0.3",
    "picomatch": "^4.0.4"
  }
}
